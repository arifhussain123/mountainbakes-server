{
  "name": "mountain-bakes-server",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "tsx watch server.ts",
    "start": "tsx server.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "purge:price-history": "tsx --env-file .env src/scripts/purge-price-history.ts",
    "deploy:firebase": "npx --yes firebase-tools deploy --only firestore:rules,firestore:indexes,storage --project mountain-bakes",
    "deploy:rules": "npx --yes firebase-tools deploy --only firestore:rules,storage --project mountain-bakes",
    "deploy:indexes": "npx --yes firebase-tools deploy --only firestore:indexes --project mountain-bakes"
  },
  "dependencies": {
    "@supabase/server": "^1.4.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.109.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^12.7.0",
    "helmet": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.15.2",
    "tsx": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.13.9",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.17.0",
    "supabase": "^2.109.1",
    "typescript": "^5.6.3"
  }
}
