# Server (Express API) env — copy to server/.env for local dev.
# On a host (Heroku et al.) set these as config vars instead; nothing here is read
# from the frontend repo, which has its own .env.example.
#
# Only the Supabase pair below is required — the server throws on boot without it.
# Everything else has a working default; the comments give it.

# ─── Supabase (auth + database) ───────────────────────────────────────────────
# REQUIRED. Project URL — Supabase -> Settings -> API. No trailing slash.
SUPABASE_URL=https://your-project-ref.supabase.co

# REQUIRED. The SECRET (service_role) key, not the anon/publishable one.
# Grants full admin access: it bypasses RLS and can manage any auth user, which is
# exactly what src/config/supabase.ts relies on — every route's authorization is
# enforced in application code (middleware/requireRole + per-handler scoping)
# rather than by RLS. NEVER expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# ─── HTTP ─────────────────────────────────────────────────────────────────────
# PORT wins when set — hosts inject it themselves, so leave it alone locally.
# API_PORT is the local-dev fallback. With neither set the server listens on 3001.
# PORT=
API_PORT=3001

# Comma-separated browser origins allowed to call this API — scheme + host, no
# trailing slash, no path. Must match the web origin EXACTLY or the browser blocks
# the request with no server-side error to go on. localhost/127.0.0.1 are always
# allowed regardless. Falls back to NEXT_PUBLIC_WEB_URL, then http://localhost:3000;
# server.ts warns at boot if this is unset while NODE_ENV=production.
CORS_ORIGINS=http://localhost:3000

# The web app's public origin. Read here only as the CORS_ORIGINS fallback, so it
# can be left unset if CORS_ORIGINS is spelled out. (The name is shared with the
# frontend's own copy of this variable — this is not a NEXT_PUBLIC_* leak.)
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Set by the host in production. Controls two things: 5xx error bodies stop
# carrying internal detail (middleware/errorHandler.ts), and the CORS warning above
# becomes active. Leave unset locally.
# NODE_ENV=production

# ─── Closing-summary messaging (SMS / WhatsApp) ───────────────────────────────
# With all of this unset the server runs the LOG provider: daily closing summaries
# are written to the server log and recorded in notification_logs, but nothing
# reaches a real phone. That is a deliberate fallback, not a failure — a missing
# credential must never take down the nightly closing job — and the admin
# Notification Recipients page shows a "Test mode" banner while it is in effect.

# 'twilio' | 'log'. Leave unset to auto-detect: Twilio when its credentials below
# are complete, otherwise log. Setting 'twilio' with incomplete credentials logs a
# warning and still falls back.
# NOTIFICATION_PROVIDER=twilio

# Twilio credentials — Twilio Console -> Account Info. A provider is only
# considered configured when SID and token are both present AND at least one of the
# two senders is set; anything less falls back to the log provider.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SMS-capable Twilio number, E.164 with the leading +.
# TWILIO_SMS_FROM=+14155551234

# WhatsApp sender, E.164 — the code adds the `whatsapp:` prefix itself, so do NOT
# include it here. NOTE: outside a 24-hour customer-service window Meta only allows
# PRE-APPROVED TEMPLATE messages, and a daily closing summary is an unsolicited
# business-initiated message. In production the body must match an approved
# template or Twilio rejects it with error 63016.
# TWILIO_WHATSAPP_FROM=+14155238886

# Retry policy for a failed send. Attempt N waits NOTIFICATION_RETRY_DELAY_MS * N
# (linear backoff). maxAttempts counts the first try, so 3 = one send + two retries.
# NOTIFICATION_RETRY_MAX=3
# NOTIFICATION_RETRY_DELAY_MS=2000

# ─── Seeding (node scripts/seed.js only) ──────────────────────────────────────
# Read solely by the seed script; the running server never looks at them. The
# defaults shown are the ones baked into scripts/seed.js — override them for
# anything you would not want to be public knowledge, and change the passwords
# immediately after seeding a real environment.
# SEED_ADMIN_EMAIL=admin@mountainbakes.com
# SEED_ADMIN_PASSWORD=Admin@123
# SEED_MANAGER_EMAIL=dha.manager@mountainbakes.com
# SEED_MANAGER_PASSWORD=Manager@123
# SEED_MANAGER2_EMAIL=gulshan.manager@mountainbakes.com
# SEED_MANAGER2_PASSWORD=Manager@123
# SEED_PRODUCTION_EMAIL=production@mountainbakes.com
# SEED_PRODUCTION_PASSWORD=Production@123

# ─── Not read yet ─────────────────────────────────────────────────────────────
# Present in some existing .env files, for the pending @supabase/server migration.
# Nothing in src/ reads these today — SUPABASE_SERVICE_ROLE_KEY above is what the
# server actually uses. SUPABASE_SECRET_KEY holds the same secret under the newer
# Supabase key naming.
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# SUPABASE_SECRET_KEY=sb_secret_xxx
# SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
