# Server (Express API) env — copy to server/.env for local dev.
# On Heroku, set these as config vars instead (there is no .env file in the dyno).

# Firebase Admin (server only — NEVER expose). LOCAL DEV: path to the JSON file,
# relative to this server/ folder (the real key lives at server/credentials/).
FIREBASE_SERVICE_ACCOUNT_PATH=./credentials/serviceAccount.json
# PRODUCTION (Heroku/etc. — no file in the container): set ONE of these instead.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account", ... }
# FIREBASE_SERVICE_ACCOUNT_BASE64=

# Firebase project (Admin init + storage bucket)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=mountain-bakes
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=mountain-bakes.firebasestorage.app

# HTTP
API_PORT=3001
# Comma-separated browser origins allowed to call the API (CORS). In production,
# your deployed web origin, e.g. https://mountain-bakes-web.herokuapp.com
CORS_ORIGINS=http://localhost:3000
NODE_ENV=development

# ─── Supabase (Auth) ──────────────────────────────────────────────────────────
# Project ref: wzjabtuoxrvyareptddq
SUPABASE_URL=https://wzjabtuoxrvyareptddq.supabase.co
# service_role secret key (server only — NEVER expose). Supabase -> Settings -> API
SUPABASE_SERVICE_ROLE_KEY=
# Phase 2 (data layer) — Postgres connection. Fill [YOUR-PASSWORD].
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.wzjabtuoxrvyareptddq.supabase.co:5432/postgres

# Newer Supabase key naming (used by @supabase/server). Real values go in .env —
# this file is COMMITTED, so it must only ever contain placeholders.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_JWKS_URL=https://wzjabtuoxrvyareptddq.supabase.co/auth/v1/.well-known/jwks.json